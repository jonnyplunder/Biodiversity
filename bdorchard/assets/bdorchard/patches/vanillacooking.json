[
  // Add fruit to cooking pots attributes
  // Add fruit to jam recipies
  // Jam Textures
  {
    "file": "game:blocktypes/clay/fired/pot",
    "op": "addmerge",
    "path": "/textures",
    "value": { "fruit-apricot": { "base": "bdorchard:block/food/pie/fill-apricot" },
     "fruit-fig": { "base": "bdorchard:block/food/pie/fill-fig" },
     "fruit-grapefruit": { "base": "bdorchard:block/food/pie/fill-grapefruit" },
     "fruit-lemon": { "base": "bdorchard:block/food/pie/fill-lemon" },
     "fruit-lime": { "base": "bdorchard:block/food/pie/fill-lime" },
     "fruit-nectarine": { "base": "bdorchard:block/food/pie/fill-nectarine" },
     "fruit-sandpear": { "base": "bdorchard:block/food/pie/fill-sandpear" }
    }
  },
  {
    "file": "game:blocktypes/clay/fired/pot",
    "op": "addmerge",
    "path": "/attributesByType/claypot-blue-cooked/textureMapping",
    "value": {
      "fruit-apricot": [ "fruit", "fruit-apricot" ],
      "fruit-fig": [ "fruit", "fruit-fig" ],
      "fruit-grapefruit": [ "fruit", "fruit-grapefruit" ],
      "fruit-lemon": [ "fruit", "fruit-lemon" ],
      "fruit-lime": [ "fruit", "fruit-lime" ],
      "fruit-nectarine": [ "fruit", "fruit-nectarine" ],
      "fruit-sandpear": [ "fruit", "fruit-sandpear" ]
    }
  },
  //apricot
  {
    "file": "game:recipes/cooking/jam.json",
