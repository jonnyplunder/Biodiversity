[
  // Leek veg-basket whitelist
  {
    "dependsOn": [ { "modid": "foodshelves" } ],
    "file": "foodshelves:config/restrictions/baskets/vegetablebasket.json",
    "op": "addmerge",
    "path": "/GroupingCodes/long",
    "value": [
      "bdcrop:vegetable-leek"
    ]
  },
  // Tomato and Potato veg-basket whitelist
  {
    "dependsOn": [ { "modid": "foodshelves" } ],
    "file": "foodshelves:config/restrictions/baskets/vegetablebasket.json",
    "op": "addmerge",
    "path": "/GroupingCodes/standard",
    "value": [
      "bdcrop:vegetable-potato",
      "bdcrop:vegetable-tomato"
    ]
  },
  // ===== Vegetable translations =====
